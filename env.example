# Copy this file to .env for local testing. On Render, set these as
# environment variables in the dashboard instead (see render.yaml).

# --- Telegram ---
BOT_TOKEN=ТОКЕН БОТА СЮДА
# Your numeric Telegram user id (send /start to @userinfobot to get it)
ADMIN_IDS=123456789

# --- AI backend (OpenAI-compatible) ---
# huihui.ai does not host an API itself - it only publishes model weights.
# This setup runs one of them on YOUR PC with Ollama, behind ollama_proxy.py
# (adds the API-key check Ollama lacks), exposed via a tunnel so Render can
# reach it. See README.md "Self-hosting with your own PC".
#
# AI_BASE_URL is the public tunnel URL + /v1 (NOT localhost - Render is a
# separate machine in the cloud and can't see your PC's localhost).
AI_BASE_URL=https://your-tunnel-url.trycloudflare.com/v1
AI_API_KEY=СЮДА_СВОЙ_СЕКРЕТНЫЙ_КЛЮЧ
AI_MODEL=huihui_ai/qwen3-abliterated:4b-v2
AI_SYSTEM_PROMPT=You are a helpful, friendly assistant answering Telegram Business messages on behalf of the account owner. Keep replies concise and natural.
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.7

# --- Away-message (first contact template, see README) ---
AWAY_TRIGGER_WORD=Хеллоуу
AWAY_COOLDOWN_HOURS=6

# --- ollama_proxy.py (runs separately, ON YOUR PC, in front of Ollama) ---
# Not used by the bot itself - only by ollama_proxy.py. PROXY_SECRET here
# should match AI_API_KEY above.
PROXY_PORT=8000
OLLAMA_URL=http://localhost:11434
PROXY_SECRET=СЮДА_СВОЙ_СЕКРЕТНЫЙ_КЛЮЧ

# --- Storage ---
DATA_FILE=data/settings.json

# --- Web server / keep-alive (Render sets PORT and RENDER_EXTERNAL_URL automatically) ---
PORT=10000
RENDER_EXTERNAL_URL=

# --- Language ---
DEFAULT_LANG=ru
